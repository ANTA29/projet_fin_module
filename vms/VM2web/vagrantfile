Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-22.04"

  config.vm.provider "vmware_desktop" do |v|
    v.gui = false
    v.linked_clone = true
  end

  config.vm.hostname = "VM2web"
  config.vm.network "private_network", ip: "192.168.100.10"

  # Route statique : pour aller vers le réseau DB (10.0), passe par la passerelle (100.1)
  config.vm.provision "shell", inline: "ip route add 192.168.10.0/24 via 192.168.100.1"
end