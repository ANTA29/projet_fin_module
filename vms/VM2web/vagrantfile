Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-22.04"

  config.vm.provider "vmware_desktop" do |v|
    v.gui = true
    v.linked_clone = true
  end

  config.vm.hostname = "VM2web"
  config.vm.network "private_network", ip: "192.168.100.10"
  
  config.vm.provision "shell", inline: "ip route add 192.168.10.0/24 via 192.168.100.1"

  config.vm.provision "shell", inline: <<-SHELL
    sudo apt-get update
    sudo apt-get install -y nginx nodejs npm

    sudo mkdir -p /var/www/node-app
    # Configuration Nginx (Reverse Proxy Port 80 -> Port 3000)
    cat <<EOF | sudo tee /etc/nginx/sites-available/default
server {
    listen 80;
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host \$host;
    }
}
EOF
    sudo systemctl restart nginx

    # Lancement de l'app Node.js en arrière-plan
    if [ -d "/var/www/node-app" ]; then
      cd /var/www/node-app && node app.js &
    fi
  SHELL
end